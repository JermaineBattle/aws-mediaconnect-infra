################################################################################
# MODE SELECTION
################################################################################
# Set this to true to use an existing VPC, false to create a new one
use_existing_vpc = false

################################################################################
# General Configuration
################################################################################
aws_region   = ""
environment  = ""
project_name = ""

################################################################################
# Option 1: EXISTING VPC Configuration (use_existing_vpc = true)
################################################################################
# Uncomment and fill these in if using an existing VPC:
# existing_vpc_id = ""
#
# existing_subnet_ids = {
#   "subnet-1" = ""
#   "subnet-2" = ""
# }

################################################################################
# Option 2: NEW VPC Configuration (use_existing_vpc = false)
################################################################################
# Only used when creating a new VPC:
vpc_cidr = ""

public_subnets = {
  "subnet-1" = {
    cidr = ""
    az   = ""
  }
  "subnet-2" = {
    cidr = ""
    az   = ""
  }
  # Add more subnets as needed:
  # "subnet-3" = {
  #   cidr = ""
  #   az   = ""
  # }
}

# Optional: Private subnets for future use
# private_subnets = {
#   "private-1" = {
#     cidr = ""
#     az   = ""
#   }
# }

################################################################################
# Security Configuration (applies to both modes)
################################################################################
# CIDR block allowed to send streams to MediaConnect
# Use 0.0.0.0/0 for testing, restrict in production
allowed_inbound_cidr = ""
